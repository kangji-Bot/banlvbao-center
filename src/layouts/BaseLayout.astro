---
// 所有页面共享的基础布局
interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage = "/images/og-default.jpg" } = Astro.props;
const siteName = "伴旅宝";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO 基础 -->
    <title>{title} | {siteName}</title>
    <meta name="description" content={description} />

    <!-- Open Graph（微信/QQ/微博分享卡片）-->
    <meta property="og:title" content={`${title} | ${siteName}`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />

    <!-- 微信专用 -->
    <meta name="wechat:title" content={`${title} | ${siteName}`} />
    <meta name="wechat:description" content={description} />
    <meta name="wechat:image" content={new URL(ogImage, Astro.site).href} />

    <!-- 禁止百度转码 -->
    <meta http-equiv="Cache-Control" content="no-transform" />
    <meta http-equiv="Cache-Control" content="no-siteapp" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/src/styles/global.css" />

    <!-- 统计预留 -->
    <!-- <script src="https://hm.baidu.com/hm.js?YOUR_ID"></script> -->
  </head>

  <body class="min-h-screen flex flex-col">

    <!-- ====== 顶部公告栏 ====== -->
    <div id="announcement-bar" class="bg-brand-600 text-white text-xs sm:text-sm text-center py-2 px-4 relative">
      <span class="font-medium">🎉 新品上线 · 30天无忧退换 · 加热包全国包邮</span>
      <button
        id="announcement-close"
        class="absolute right-3 top-1/2 -translate-y-1/2 text-white/70 hover:text-white p-1"
        aria-label="关闭公告"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- ====== 桌面端导航栏 ====== -->
    <header id="site-header" class="sticky top-0 z-50 bg-warm-50/95 backdrop-blur border-b border-warm-200">
      <nav class="container-main flex items-center justify-between h-16">
        <a href="/" class="text-xl font-bold text-brand-600 hover:text-brand-700 transition-colors shrink-0">
          🏷️ {siteName}
        </a>

        <!-- 桌面端导航 -->
        <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-warm-600">
          <li><a href="/product" class="hover:text-brand-600 transition-colors">产品</a></li>
          <li><a href="/guide" class="hover:text-brand-600 transition-colors">使用指南</a></li>
          <li><a href="/story" class="hover:text-brand-600 transition-colors">品牌故事</a></li>
          <li><a href="/buy" class="hover:text-brand-600 transition-colors">购买渠道</a></li>
          <li>
            <a href="/buy" class="px-4 py-2 bg-brand-500 text-white rounded-full hover:bg-brand-600 transition-colors text-sm font-medium">
              立即购买
            </a>
          </li>
        </ul>

        <!-- 移动端菜单按钮 -->
        <button id="mobile-menu-btn" class="md:hidden p-2 text-warm-600 hover:text-brand-600" aria-label="打开菜单">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>
      </nav>
    </header>

    <!-- ====== 移动端侧滑菜单 ====== -->
    <div id="mobile-overlay" class="fixed inset-0 bg-black/50 z-40 hidden md:hidden" aria-hidden="true"></div>
    <div id="mobile-drawer" class="fixed top-0 right-0 h-full w-64 bg-warm-50 z-50 shadow-2xl translate-x-full transition-transform duration-300 md:hidden">
      <div class="flex items-center justify-between p-4 border-b border-warm-200">
        <span class="font-bold text-brand-600">菜单</span>
        <button id="mobile-drawer-close" class="p-1 text-warm-600" aria-label="关闭菜单">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <ul class="p-4 space-y-2">
        <li><a href="/product" class="block px-3 py-3 rounded-lg hover:bg-warm-100 font-medium">📦 产品详情</a></li>
        <li><a href="/guide" class="block px-3 py-3 rounded-lg hover:bg-warm-100 font-medium">📖 使用指南</a></li>
        <li><a href="/story" class="block px-3 py-3 rounded-lg hover:bg-warm-100 font-medium">💡 品牌故事</a></li>
        <li><a href="/buy" class="block px-3 py-3 rounded-lg hover:bg-warm-100 font-medium">🛒 购买渠道</a></li>
        <li class="pt-3"><a href="/buy" class="block text-center px-4 py-3 bg-brand-500 text-white rounded-full font-medium">立即购买</a></li>
      </ul>
    </div>

    <!-- ====== 页面主体 ====== -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- ====== 页脚 ====== -->
    <footer class="bg-warm-800 text-warm-300 py-12 pb-24 md:pb-12">
      <div class="container-main">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-white font-bold text-lg mb-3">{siteName}</h3>
            <p class="text-sm leading-relaxed">
              伴旅宝自加热控温杯 · 旅途中的温暖陪伴。<br />
              无需插电，随时随地，一口暖到胃。
            </p>
          </div>
          <div>
            <h4 class="text-white font-medium mb-3">快速链接</h4>
            <ul class="space-y-2 text-sm">
              <li><a href="/product" class="hover:text-white transition-colors">产品详情</a></li>
              <li><a href="/guide" class="hover:text-white transition-colors">使用指南</a></li>
              <li><a href="/story" class="hover:text-white transition-colors">品牌故事</a></li>
              <li><a href="/buy" class="hover:text-white transition-colors">购买渠道</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-white font-medium mb-3">关注我们</h4>
            <div class="flex gap-4">
              <a href="#" class="hover:text-white transition-colors text-sm" title="微信公众号">微信公众号</a>
              <a href="#" class="hover:text-white transition-colors text-sm" title="视频号">视频号</a>
              <a href="#" class="hover:text-white transition-colors text-sm" title="小红书">小红书</a>
              <a href="#" class="hover:text-white transition-colors text-sm" title="抖音">抖音</a>
            </div>
          </div>
        </div>
        <div class="mt-8 pt-8 border-t border-warm-700 text-center text-xs text-warm-500">
          <p>
            &copy; {new Date().getFullYear()} {siteName}. All rights reserved.
            &nbsp;|&nbsp;
            <a href="#" class="hover:text-warm-400 transition-colors">ICP备案号待填入</a>
          </p>
        </div>
      </div>
    </footer>

    <!-- ====== 移动端底部固定CTA ====== -->
    <div id="mobile-bottom-bar" class="fixed bottom-0 left-0 right-0 z-50 md:hidden bg-white/95 backdrop-blur border-t border-warm-200 px-4 py-3 flex items-center gap-3">
      <a href="/buy" class="flex-1 text-center py-3 bg-brand-500 text-white font-medium text-base rounded-full active:scale-95 transition-transform shadow-lg shadow-brand-200">
        🛒 立即购买
      </a>
      <a href="/product" class="shrink-0 p-3 text-warm-500 hover:text-brand-600 transition-colors" aria-label="产品详情">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      </a>
    </div>

    <!-- ====== 全局 JS ====== -->
    <script>
      // 公告栏关闭
      const bar = document.getElementById('announcement-bar');
      const closeBtn = document.getElementById('announcement-close');
      closeBtn?.addEventListener('click', () => {
        bar.style.display = 'none';
        // 调整 sticky header 位置
        document.getElementById('site-header').style.top = '0';
      });

      // 移动端侧滑菜单
      const menuBtn = document.getElementById('mobile-menu-btn');
      const drawer = document.getElementById('mobile-drawer');
      const overlay = document.getElementById('mobile-overlay');
      const drawerClose = document.getElementById('mobile-drawer-close');

      function openDrawer() {
        drawer.classList.remove('translate-x-full');
        overlay.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
      function closeDrawer() {
        drawer.classList.add('translate-x-full');
        overlay.classList.add('hidden');
        document.body.style.overflow = '';
      }

      menuBtn?.addEventListener('click', openDrawer);
      drawerClose?.addEventListener('click', closeDrawer);
      overlay?.addEventListener('click', closeDrawer);

      // 底部CTA显示/隐藏逻辑：Hero区可见时隐藏，滚动过Hero后显示
      const bottomBar = document.getElementById('mobile-bottom-bar');
      if (bottomBar && window.innerWidth < 768) {
        let ticking = false;
        window.addEventListener('scroll', () => {
          if (!ticking) {
            requestAnimationFrame(() => {
              const hero = document.querySelector('section');
              if (hero) {
                const heroBottom = hero.getBoundingClientRect().bottom;
                bottomBar.style.transform = heroBottom > 100 ? 'translateY(100%)' : 'translateY(0)';
                bottomBar.style.transition = 'transform 0.3s ease';
              }
              ticking = false;
            });
            ticking = true;
          }
        }, { passive: true });
      }
    </script>
  </body>
</html>
