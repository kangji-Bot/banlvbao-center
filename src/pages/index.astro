---
// 首页
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import BuyButton from "../components/BuyButton.astro";
---

<BaseLayout
  title="首页"
  description="伴旅宝自加热控温杯——食品级加热包速热，无需插电，全链路食品级材质，300ml容量，45~55°C暖胃控温。随时随地喝到理想温度的水。"
>
  <!-- ===== Hero 区 ===== -->
  <Hero />

  <!-- ===== 产品亮点速览 ===== -->
  <section class="section bg-warm-50">
    <div class="container-main">
      <h2 class="text-3xl sm:text-4xl font-bold text-center text-warm-900">
        为什么选择伴旅宝
      </h2>
      <p class="mt-4 text-center text-warm-500 max-w-xl mx-auto">
        不是保温杯，不是电热杯，是一种全新的自加热方式
      </p>
      <div class="mt-12 grid gap-8 md:grid-cols-3">
        <div class="text-center p-6 rounded-2xl bg-white shadow-sm hover:shadow-md transition-shadow">
          <div class="text-4xl mb-4">🔥</div>
          <h3 class="text-xl font-bold text-warm-900 mb-2">加热包速热 · 无需插电</h3>
          <p class="text-warm-500 text-sm leading-relaxed">
            食品级专用加热包，遇水即热。无需电池、无需充电、无需电源插座，随时随地一杯热水。
          </p>
        </div>
        <div class="text-center p-6 rounded-2xl bg-white shadow-sm hover:shadow-md transition-shadow">
          <div class="text-4xl mb-4">🌡️</div>
          <h3 class="text-xl font-bold text-warm-900 mb-2">45~55°C 暖胃控温</h3>
          <p class="text-warm-500 text-sm leading-relaxed">
            精准控制在暖胃最适温度区间。不烫口、不伤胃，入口刚刚好。每一口都是恰到好处的温暖。
          </p>
        </div>
        <div class="text-center p-6 rounded-2xl bg-white shadow-sm hover:shadow-md transition-shadow">
          <div class="text-4xl mb-4">🛡️</div>
          <h3 class="text-xl font-bold text-warm-900 mb-2">全链路食品级材质</h3>
          <p class="text-warm-500 text-sm leading-relaxed">
            杯盖/内胆/外杯体采用PP聚合物，密封圈为食品级硅橡胶，加热包亦为食品级配方。从内到外，每一处都安心。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 工作原理（新品类需要教育用户） ===== -->
  <section class="section bg-white">
    <div class="container-main">
      <h2 class="text-3xl sm:text-4xl font-bold text-center text-warm-900">
        怎么做到的？
      </h2>
      <p class="mt-4 text-center text-warm-500 max-w-xl mx-auto">
        三步，一杯热水。比你想象中更简单。
      </p>
      <div class="mt-12 grid gap-8 md:grid-cols-3">
        <div class="text-center">
          <div class="mx-auto w-16 h-16 rounded-full bg-brand-100 flex items-center justify-center text-2xl font-bold text-brand-600">1</div>
          <h3 class="mt-4 font-bold text-warm-900">放入加热包</h3>
          <p class="mt-2 text-sm text-warm-500">
            撕开包装，放入杯体底部加热仓
          </p>
        </div>
        <div class="text-center">
          <div class="mx-auto w-16 h-16 rounded-full bg-brand-100 flex items-center justify-center text-2xl font-bold text-brand-600">2</div>
          <h3 class="mt-4 font-bold text-warm-900">加入饮品</h3>
          <p class="mt-2 text-sm text-warm-500">
            倒入水、茶或咖啡，拧紧杯盖
          </p>
        </div>
        <div class="text-center">
          <div class="mx-auto w-16 h-16 rounded-full bg-brand-100 flex items-center justify-center text-2xl font-bold text-brand-600">3</div>
          <h3 class="mt-4 font-bold text-warm-900">等待升温</h3>
          <p class="mt-2 text-sm text-warm-500">
            加热包遇水自动启动，数分钟达到45~55°C
          </p>
        </div>
      </div>
      <p class="mt-8 text-center">
        <a href="/guide" class="text-brand-600 font-medium hover:underline text-sm">
          查看详细使用指南 →
        </a>
      </p>
    </div>
  </section>

  <!-- ===== 使用场景（生活方式展示） ===== -->
  <section class="section bg-warm-50">
    <div class="container-main">
      <h2 class="text-3xl sm:text-4xl font-bold text-center text-warm-900">
        你的移动热饮站
      </h2>
      <p class="mt-4 text-center text-warm-500 max-w-xl mx-auto">
        没有电源？不是问题。伴旅宝在任何地方都能给你一杯热的。
      </p>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        <div class="rounded-2xl overflow-hidden bg-white shadow-sm hover:shadow-md transition-shadow">
          <div class="h-48 bg-warm-100 flex items-center justify-center text-warm-400">
            🚗 场景图：车内使用
          </div>
          <div class="p-5">
            <h3 class="font-bold text-warm-900">通勤路上</h3>
            <p class="mt-1 text-sm text-warm-500">堵车时，来一口热咖啡。无需下车，无需找便利店。</p>
          </div>
        </div>
        <div class="rounded-2xl overflow-hidden bg-white shadow-sm hover:shadow-md transition-shadow">
          <div class="h-48 bg-warm-100 flex items-center justify-center text-warm-400">
            ⛰️ 场景图：户外使用
          </div>
          <div class="p-5">
            <h3 class="font-bold text-warm-900">户外出行</h3>
            <p class="mt-1 text-sm text-warm-500">露营、登山、钓鱼——没有电源的地方，伴旅宝就是你的移动热水站。</p>
          </div>
        </div>
        <div class="rounded-2xl overflow-hidden bg-white shadow-sm hover:shadow-md transition-shadow">
          <div class="h-48 bg-warm-100 flex items-center justify-center text-warm-400">
            💼 场景图：办公使用
          </div>
          <div class="p-5">
            <h3 class="font-bold text-warm-900">办公桌前</h3>
            <p class="mt-1 text-sm text-warm-500">会议连轴转忘了喝水？一包加热，给忙碌的工作日一杯暖意。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 购买渠道入口 ===== -->
  <section class="section bg-brand-50">
    <div class="container-main text-center">
      <h2 class="text-3xl font-bold text-warm-900">选择你习惯的平台下单</h2>
      <p class="mt-3 text-warm-500">多平台官方店铺，正品保障 · 统一售后</p>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <a href="/buy#taobao" class="block p-5 rounded-2xl bg-white shadow-sm hover:shadow-md transition-shadow">
          <div class="text-2xl mb-2">🛒</div>
          <h4 class="font-bold text-warm-900">淘宝</h4>
          <p class="text-xs text-warm-500 mt-1">官方旗舰店</p>
        </a>
        <a href="/buy#jd" class="block p-5 rounded-2xl bg-white shadow-sm hover:shadow-md transition-shadow">
          <div class="text-2xl mb-2">🐶</div>
          <h4 class="font-bold text-warm-900">京东</h4>
          <p class="text-xs text-warm-500 mt-1">官方旗舰店</p>
        </a>
        <a href="/buy#douyin" class="block p-5 rounded-2xl bg-white shadow-sm hover:shadow-md transition-shadow">
          <div class="text-2xl mb-2">🎵</div>
          <h4 class="font-bold text-warm-900">抖音</h4>
          <p class="text-xs text-warm-500 mt-1">官方小店</p>
        </a>
        <a href="/buy#wechat" class="block p-5 rounded-2xl bg-white shadow-sm hover:shadow-md transition-shadow">
          <div class="text-2xl mb-2">💬</div>
          <h4 class="font-bold text-warm-900">微信小店</h4>
          <p class="text-xs text-warm-500 mt-1">官方店铺</p>
        </a>
        <a href="/buy#pdd" class="block p-5 rounded-2xl bg-white shadow-sm hover:shadow-md transition-shadow">
          <div class="text-2xl mb-2">🔻</div>
          <h4 class="font-bold text-warm-900">拼多多</h4>
          <p class="text-xs text-warm-500 mt-1">官方旗舰店</p>
        </a>
        <a href="/buy#vipshop" class="block p-5 rounded-2xl bg-white shadow-sm hover:shadow-md transition-shadow">
          <div class="text-2xl mb-2">🛍️</div>
          <h4 class="font-bold text-warm-900">唯品会</h4>
          <p class="text-xs text-warm-500 mt-1">官方店铺</p>
        </a>
        <a href="/buy#1688" class="block p-5 rounded-2xl bg-white shadow-sm hover:shadow-md transition-shadow">
          <div class="text-2xl mb-2">🏭</div>
          <h4 class="font-bold text-warm-900">1688</h4>
          <p class="text-xs text-warm-500 mt-1">官方店铺</p>
        </a>
        <a href="/buy#amazon" class="block p-5 rounded-2xl bg-white shadow-sm hover:shadow-md transition-shadow">
          <div class="text-2xl mb-2">📦</div>
          <h4 class="font-bold text-warm-900">亚马逊</h4>
          <p class="text-xs text-warm-500 mt-1">Amazon</p>
        </a>
      </div>
      <div class="mt-10">
        <BuyButton text="前往购买指南" size="lg" />
      </div>
    </div>
  </section>

  <!-- ===== 加热包复购（利润核心） ===== -->
  <section class="section bg-white">
    <div class="container-main">
      <div class="rounded-2xl bg-gradient-to-br from-brand-50 to-orange-50 border border-brand-200 p-8 md:p-12 flex flex-col md:flex-row items-center gap-8">
        <div class="flex-1 text-center md:text-left">
          <span class="inline-block bg-brand-500 text-white text-xs font-bold px-3 py-1 rounded-full mb-3">耗材补给</span>
          <h2 class="text-2xl sm:text-3xl font-bold text-warm-900">加热包补充装</h2>
          <p class="mt-4 text-warm-600 leading-relaxed">
            每个加热包为一次性使用。建议常备补充装，随时享受暖饮自由。
            食品级配方（铝粉、氧化钙、碳酸钠、碳酸氢钠、活性炭），安全无忧。
          </p>
          <div class="mt-6">
            <BuyButton text="购买加热包补充装" href="/buy" variant="primary" />
          </div>
        </div>
        <div class="shrink-0 w-40 h-40 rounded-2xl bg-white border-2 border-dashed border-brand-300 flex items-center justify-center text-brand-400 text-sm">
          🔥 加热包<br>产品图
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 用户评价（结构化占位） ===== -->
  <section class="section bg-warm-50">
    <div class="container-main text-center">
      <h2 class="text-3xl font-bold text-warm-900">用户怎么说</h2>
      <p class="mt-3 text-warm-500">真实体验，比任何广告都有说服力</p>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        <div class="p-6 rounded-2xl bg-white border border-warm-200 text-left">
          <div class="text-brand-400 text-lg mb-3">★★★★★</div>
          <p class="text-sm text-warm-600 leading-relaxed italic">"出差神器。高铁上没有热水也不用等乘务员，自己加热几分钟就能喝。"</p>
          <p class="mt-4 text-xs text-warm-400">—— 用户评价占位，收集到真实反馈后替换</p>
        </div>
        <div class="p-6 rounded-2xl bg-white border border-warm-200 text-left">
          <div class="text-brand-400 text-lg mb-3">★★★★★</div>
          <p class="text-sm text-warm-600 leading-relaxed italic">"带娃出门冲奶粉太方便了！不用到处找热水，温度刚好不烫嘴。"</p>
          <p class="mt-4 text-xs text-warm-400">—— 用户评价占位，收集到真实反馈后替换</p>
        </div>
        <div class="p-6 rounded-2xl bg-white border border-warm-200 text-left">
          <div class="text-brand-400 text-lg mb-3">★★★★★</div>
          <p class="text-sm text-warm-600 leading-relaxed italic">"冬天钓鱼的救星。在河边坐半天，随时来一口热水，幸福感拉满。"</p>
          <p class="mt-4 text-xs text-warm-400">—— 用户评价占位，收集到真实反馈后替换</p>
        </div>
      </div>
      <p class="mt-6 text-xs text-warm-400">
        ⚠️ 以上为场景模拟文案，仅供预览页面效果。上线前替换为真实用户评价。
      </p>
    </div>
  </section>

  <!-- ===== 底部CTA ===== -->
  <section class="section bg-brand-600 text-white text-center">
    <div class="container-main">
      <h2 class="text-3xl font-bold">准备好升级你的喝水体验了吗？</h2>
      <p class="mt-4 text-brand-100">多平台官方店铺，正品保障，30天无忧退换</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <BuyButton text="🛒 立即购买" variant="white" size="lg" />
        <a href="/guide" class="inline-block px-8 py-4 border-2 border-white text-white font-medium text-lg rounded-full hover:bg-white hover:text-brand-600 transition-all active:scale-95">
          📖 查看使用指南
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
